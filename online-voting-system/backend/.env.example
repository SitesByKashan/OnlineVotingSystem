APP_SECRET=change-this-secret-before-demo
DATABASE_PATH=smartvote.db
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE=http://localhost:8000
ACCESS_TOKEN_MINUTES=480
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
SHOW_DEV_OTP=false

# Optional Firebase / Firestore configuration.
# Put your Firebase service account JSON path here when you want Firestore sync.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_PATH=backend/firebase-service-account.json

# Optional real email delivery.
# For Gmail, use an app password, not your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=SmartVote <your-email@gmail.com>
